# ── Local dev (.env) — uvicorn + celery on host, Postgres/Redis on localhost ──
# Use 127.0.0.1 (NOT "postgres" or "redis" — those are Docker service names).
# Password must match your Postgres instance (docker-compose postgres uses "postgres").
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/actowiz_rag
DATABASE_SYNC_URL=postgresql://postgres:postgres@127.0.0.1:5432/actowiz_rag

REDIS_URL=redis://localhost:6379/0

EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384

RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_N=5

SIMILARITY_TOP_K=15

STRUCTURE_CHUNK_MAX_CHARS=1200
PAGE_CHUNK_OVERLAP_CHARS=200
CODE_CHUNK_LINES=40
CODE_CHUNK_OVERLAP=15
CODE_CHUNK_MAX_CHARS=1500
PDF_NATIVE_TEXT_MIN_CHARS=300
PADDLEOCR_LANG=en
PADDLEOCR_DPI=200
OCR_DPI=300

STORAGE_DIR=./storage/uploads

LLM_PROVIDER=groq
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_API_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.1-8b-instant
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1

APP_ENV=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
