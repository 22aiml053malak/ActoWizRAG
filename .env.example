# ── Database ──────────────────────────────────────────────────────────────────
# Provide your PostgreSQL connection URLs with pgvector installed.
# Replace <user>, <password>, <host>, <port>, <dbname> with your actual values.
#
# Async connection string (used by SQLAlchemy 2.x async engine + FastAPI)
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>

# Sync connection string (used by PGVectorStore and Celery task DB calls)
DATABASE_SYNC_URL=postgresql://<user>:<password>@<host>:<port>/<dbname>

# Example (local docker-compose):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/actowiz_rag
# DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/actowiz_rag

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Embedding ─────────────────────────────────────────────────────────────────
# HuggingFace model name — do NOT change unless you also update EMBED_DIM
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Embedding dimensionality — MUST match the model output AND PGVectorStore embed_dim.
# all-MiniLM-L6-v2 outputs 384-dim vectors. Changing this will cause
# "different vector dimensions" errors in pgvector.
EMBED_DIM=384

# ── Reranker ─────────────────────────────────────────────────────────────────
RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_N=5

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Wide candidate set for initial vector search (before reranking).
# Keep at 15 — more candidates → better reranking accuracy, more latency.
SIMILARITY_TOP_K=15

# ── Chunking ─────────────────────────────────────────────────────────────────
SENTENCE_WINDOW_SIZE=3
CODE_CHUNK_LINES=40
CODE_CHUNK_OVERLAP=15
CODE_CHUNK_MAX_CHARS=1500

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_DIR=./storage/uploads

# ── LLM / AI Gateway (Groq) ──────────────────────────────────────────────────
# This project uses Groq as the default LLM provider for answer generation.
# Get a free API key at https://console.groq.com
#
# Set LLM_PROVIDER=groq and add your GROQ_API_KEY to enable generate_answer=true.
LLM_PROVIDER=groq

# Your Groq API key (starts with gsk_...)
LLM_API_KEY=gsk_your_groq_api_key_here

# Groq API base URL (do not change for Groq Cloud)
LLM_API_BASE_URL=https://api.groq.com/openai/v1

# Groq model to use for answer synthesis.
# Recommended options (fast + capable on Groq):
#   - llama3-8b-8192       (fast, good quality, 8192 context)
#   - llama3-70b-8192      (higher quality, slightly slower)
#   - mixtral-8x7b-32768   (32k context window, good for long documents)
LLM_MODEL_NAME=llama3-8b-8192
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
